# Copy this file to .env and fill in your values
# OpenAI or compatible API settings
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Server settings
PORT=3001
NODE_ENV=development

# Production CORS — set to your Railway frontend URL (no trailing slash)
# ALLOWED_ORIGIN=https://recipe-generator-client.up.railway.app
